{
  "name": "template",
  "version": "4.2.0",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0 <12"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:background": "astro dev --background",
    "dev:status": "astro dev status",
    "dev:logs": "astro dev logs",
    "dev:stop": "astro dev stop",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check . --plugin=prettier-plugin-astro",
    "format": "prettier --write . --plugin=prettier-plugin-astro",
    "cz": "cz",
    "prepare": "husky install",
    "lint": "eslint .",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "podcast:generate": "uv run podcast-generate --all",
    "podcast:generate:force": "uv run podcast-generate --all --force",
    "podcast:generate:one": "uv run podcast-generate --posts",
    "podcast:dry-run": "uv run podcast-generate --all --dry-run",
    "podcast:help": "uv run podcast-generate --help"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.0.0",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.3.0",
    "github-slugger": "^2.0.0",
    "mermaid": "^11.15.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "rss": "^1.2.2",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/rss": "^0.0.32",
    "@typescript-eslint/parser": "^8.62.0",
    "astro-eslint-parser": "^2.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,astro}": [
      "prettier --write --plugin=prettier-plugin-astro"
    ]
  }
}
