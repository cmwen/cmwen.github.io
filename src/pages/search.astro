---
import { getCollection } from "astro:content";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import SearchBar from "@components/Search";
import getSortedPosts from "@utils/getSortedPosts";
import { getPostSlug } from "@utils/contentEntry";
import { defaultLocale, type Locale } from "@i18n/config";
import { messages } from "@i18n/dict";

const lang: Locale = defaultLocale;
const t = messages[lang];

// Retrieve all published EN articles
const posts = await getCollection("blog", ({ data }) => data.lang === lang);
const sortedPosts = getSortedPosts(posts);

// List of items to search in
const searchList = sortedPosts.map(post => ({
  title: post.data.title,
  description: post.data.description,
  data: post.data,
  slug: getPostSlug(post),
}));

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<Layout
  title={`${t.nav.searchAria} | ${SITE.title}`}
  lang={lang}
  alternates={{
    en: canonical,
    "zh-hant": new URL(`/zh-hant${Astro.url.pathname}`, Astro.site).href,
  }}
>
  <Header activeNav="search" {lang} />
  <Main pageTitle={t.nav.searchAria} pageDesc={t.common.searchPlaceholder}>
    <SearchBar client:load searchList={searchList} />
  </Main>
  <Footer />
</Layout>
